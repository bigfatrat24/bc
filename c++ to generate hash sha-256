#include <iostream>
#include <openssl/sha.h>
#include <iomanip>

using namespace std;

int main() {
    string input = "hello";
    unsigned char hash[SHA256_DIGEST_LENGTH];

    SHA256((unsigned char*)input.c_str(), input.length(), hash);

    cout << "SHA-256: ";
    for (int i = 0; i < SHA256_DIGEST_LENGTH; i++) {
        cout << hex << setw(2) << setfill('0') << (int)hash[i];
    }
    cout << endl;

    return 0;
}

